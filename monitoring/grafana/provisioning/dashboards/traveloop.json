{
  "title": "Traveloop Backend",
  "uid": "traveloop-backend",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total[1m])) by (method, route)",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "id": 2,
      "title": "Response Time P95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
        "legendFormat": "p95 {{route}}"
      }]
    },
    {
      "id": 3,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m]))",
        "legendFormat": "5xx errors/s"
      }]
    },
    {
      "id": 4,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "http_active_connections",
        "legendFormat": "Active"
      }]
    },
    {
      "id": 5,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "nodejs_heap_size_used_bytes",
        "legendFormat": "Heap Used"
      }]
    },
    {
      "id": 6,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "targets": [{
        "datasource": "Loki",
        "expr": "{app=\"traveloop\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 7,
      "title": "Gemini API Calls (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(gemini_requests_total[5m])) by (operation)",
        "legendFormat": "{{operation}}"
      }]
    },
    {
      "id": 8,
      "title": "Gemini Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(gemini_requests_total{status=\"error\"}[5m]))",
        "legendFormat": "errors/s"
      }]
    },
    {
      "id": 9,
      "title": "Gemini Response Time P95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.95, sum(rate(gemini_request_duration_seconds_bucket[5m])) by (le, operation))",
        "legendFormat": "p95 {{operation}}"
      }]
    },
    {
      "id": 10,
      "title": "Gemini Total Requests",
      "type": "stat",
      "gridPos": { "x": 12, "y": 34, "w": 6, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(gemini_requests_total)",
        "legendFormat": "Total"
      }]
    },
    {
      "id": 11,
      "title": "Gemini Estimated Tokens Used",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 34, "w": 6, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(gemini_tokens_used_total[5m])) by (operation)",
        "legendFormat": "{{operation}}"
      }]
    }
  ]
}
